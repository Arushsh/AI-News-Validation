datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Pooler URL — used at runtime (serverless-safe)
  directUrl = env("DIRECT_URL")         // Direct URL — used only for prisma db push/migrate
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // 'user', 'admin'
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  votes            Vote[]
  comments         Comment[]
  notifications    Notification[]
  submittedReports VerificationReport[] @relation("SubmittedReports")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationReport {
  id              String   @id @default(cuid())
  title           String?
  content         String?   // the claim or text
  url             String?
  authenticityScore Int
  aiGeneratedProb Int
  explanation     String?
  status          String    @default("pending") // 'pending', 'approved', 'rejected'
  category        String?   // 'Politics', 'Tech', etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submitterId     String?
  submitter       User?    @relation("SubmittedReports", fields: [submitterId], references: [id])

  votes           Vote[]
  comments        Comment[]
}

model Source {
  id              String   @id @default(cuid())
  name            String
  domain          String   @unique
  credibility     Int      @default(50)
  category        String?
  articles        Int      @default(0)
}

model Vote {
  id              String   @id @default(cuid())
  userId          String
  reportId        String
  stance          String   // 'yes', 'no'
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report          VerificationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
}

model Comment {
  id              String   @id @default(cuid())
  userId          String
  reportId        String
  content         String
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report          VerificationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  title           String
  body            String
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id            String   @id @default(cuid())
  title         String
  description   String?
  content       String?
  imageUrl      String?
  sourceUrl     String   @unique
  sourceName    String
  category      String   @default("General")
  scale         String   @default("international") // international, national, local
  publishedAt   DateTime?
  keywords      String?  // comma-separated for search matching
  dedupeHash    String   @unique // MD5 of sourceUrl for deduplication
  createdAt     DateTime @default(now())

  @@index([category])
  @@index([scale])
  @@index([publishedAt])
}
